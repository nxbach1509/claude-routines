# ═══════════════════════════════════════════════════════════
#  AI Weekly Report — Environment Variables
#  Copy file này thành .env và điền vào các giá trị thực tế:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── Bắt buộc ────────────────────────────────────────────────

# Anthropic API Key (lấy tại https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail sender (địa chỉ Gmail dùng để gửi báo cáo)
GMAIL_USER=your-sender@gmail.com

# Gmail App Password (KHÔNG phải mật khẩu Gmail thường)
# Cách tạo App Password:
#   1. Bật 2-Step Verification tại myaccount.google.com/security
#   2. Vào myaccount.google.com/apppasswords
#   3. Chọn app "Mail", device "Other (Custom name)"
#   4. Đặt tên "AI Weekly Bot", copy 16-ký-tự password
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Tuỳ chọn ────────────────────────────────────────────────

# Email nhận báo cáo (mặc định: nxbach1509@gmail.com)
RECIPIENT_EMAIL=nxbach1509@gmail.com

# Tavily Search API Key — tìm kiếm nâng cao, chính xác hơn DuckDuckGo
# Đăng ký miễn phí tại https://app.tavily.com/ (1.000 lượt/tháng free)
# Nếu để trống → tự động dùng DuckDuckGo (không cần API key)
TAVILY_API_KEY=tvly-...
